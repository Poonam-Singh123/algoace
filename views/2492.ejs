<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // n cities (1-indexed). roads[i] = [a, b, dist]: bidirectional road.
    // Graph is not necessarily connected.
    // A path from 1 to n may reuse roads and revisit cities.
    // Score of a path = MINIMUM road distance on the path.
    // Return the MINIMUM possible score of any path from 1 to n.
    //
    // Key insight — reuse allowed:
    //   Since roads and cities can be revisited, any path from 1 to n can
    //   "detour" through any road that is reachable from the same connected
    //   component as node 1 (and n). So the answer is simply the MINIMUM
    //   distance among ALL edges in the connected component containing 1.
    //
    //   Why? If the minimum-weight edge (u, v, d_min) is in the same
    //   component as 1 and n, we can always construct a path that traverses
    //   it: go from 1 to u, cross (u,v), go from v to n (using any route,
    //   possibly backtracking). The score = d_min.
    //   We cannot do better than d_min since every path uses at least one edge.
    //
    // Approach: BFS/DFS from node 1, find the minimum edge weight encountered.
    //   No need for explicit shortest-path algorithms — just traverse the
    //   component and track the minimum edge weight seen.
    //
    // Example 1: n=4, roads=[[1,2,9],[2,3,6],[2,4,5],[1,4,7]]
    //   All nodes are in one component.
    //   Min edge weight = 5 (road 2-4) → Output: 5 ✓
    //
    // Example 2: n=4, roads=[[1,2,2],[1,3,4],[3,4,7]]
    //   All in one component. Min edge = 2 → Output: 2 ✓
    //
    // Time : O(n + m)    Space: O(n + m)

    int minScore(int n, vector&lt;vector&lt;int&gt;&gt;&amp; roads) {
        // Build adjacency list (1-indexed): adj[u] = {v, dist}
        vector&lt;vector&lt;pair&lt;int,int&gt;&gt;&gt; adj(n + 1);
        for (auto&amp; r : roads) {
            adj[r[0]].push_back({r[1], r[2]});
            adj[r[1]].push_back({r[0], r[2]});
        }

        // BFS from node 1 to explore its connected component
        vector&lt;bool&gt; visited(n + 1, false);
        queue&lt;int&gt; q;
        q.push(1);
        visited[1] = true;

        int ans = INT_MAX;

        while (!q.empty()) {
            int u = q.front();
            q.pop();

            for (auto [v, d] : adj[u]) {
                // Consider every edge in the component (track min distance)
                ans = min(ans, d);

                if (!visited[v]) {
                    visited[v] = true;
                    q.push(v);
                }
            }
        }

        return ans;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
