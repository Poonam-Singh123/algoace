<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Given integer array nums and integer k:
    //   Choose exactly k non-empty subarrays (overlaps and repeats allowed).
    //   Value of subarray nums[l..r] = max(nums[l..r]) - min(nums[l..r]).
    //   Return the maximum possible SUM of values across all k chosen subarrays.
    //
    // Key insight:
    //   Since subarrays may overlap and the SAME subarray can be chosen multiple
    //   times, we are free to pick any subarray up to k times.
    //
    //   The value of a subarray is max - min, which is always &gt;= 0.
    //   To maximise the total, we should pick the subarray with the HIGHEST
    //   value exactly k times.
    //
    //   What is the maximum possible subarray value?
    //     A subarray's value = its max - its min &lt;= global_max - global_min.
    //     The whole array achieves this upper bound
    //     (or any subarray spanning the global max and min).
    //
    //   Therefore:
    //     Maximum total value = k * (max(nums) - min(nums))
    //
    // Examples:
    //   nums = [1,3,2], k = 2
    //     globalMax=3, globalMin=1  →  2 * (3-1) = 4 ✓
    //
    //   nums = [4,2,5,1], k = 3
    //     globalMax=5, globalMin=1  →  3 * (5-1) = 12 ✓
    //
    // Time : O(n)    Space: O(1)

    long long maxSubarrayValue(vector&lt;int&gt;&amp; nums, int k) {
        int globalMax = *max_element(nums.begin(), nums.end());
        int globalMin = *min_element(nums.begin(), nums.end());

        // Pick the best subarray (value = globalMax - globalMin) exactly k times
        return (long long)k * (globalMax - globalMin);
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
