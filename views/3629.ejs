<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Transformation rules (one step):
    //   'a' -> 'b'
    //   'b' -> 'c'
    //   ...
    //   'y' -> 'z'
    //   'z' -> 'a' + 'b'   (splits into TWO characters)
    //
    // After t transformations, return total length of the string mod 1e9+7.

    int lengthAfterTransformations(string s, int t) {
        const int MOD = 1e9 + 7;

        // cnt[i] = current count of character ('a' + i) in the string
        vector&lt;long long&gt; cnt(26, 0);
        for (char c : s) cnt[c - 'a']++;

        // Simulate t transformation steps.
        // Each step: every character shifts one position forward in the alphabet.
        //   'z' (index 25) splits into 'a' (index 0) + 'b' (index 1).
        // So after one step:
        //   new[0]  = old[25]          ('z' -> 'a')
        //   new[1]  = old[0] + old[25] ('a' -> 'b', and 'z' -> 'b')
        //   new[i]  = old[i-1]         for i = 2..25

        for (int step = 0; step &lt; t; step++) {
            vector&lt;long long&gt; next(26, 0);

            // 'z' becomes both 'a' and 'b'
            next[0] = cnt[25];
            next[1] = (cnt[0] + cnt[25]) % MOD;

            // All other characters simply shift right by one
            for (int i = 2; i &lt; 26; i++) {
                next[i] = cnt[i - 1] % MOD;
            }

            cnt = next;
        }

        // Sum all character counts for the final length
        long long ans = 0;
        for (int i = 0; i &lt; 26; i++) {
            ans = (ans + cnt[i]) % MOD;
        }

        return (int)ans;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
