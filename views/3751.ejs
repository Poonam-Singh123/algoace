<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Given range [num1, num2], return the sum of waviness of all numbers.
    //
    // Waviness of a number = count of its PEAKS + count of its VALLEYS.
    //   Peak:   digit strictly greater than BOTH immediate neighbours.
    //   Valley: digit strictly less than BOTH immediate neighbours.
    //   First and last digits can never be peaks/valleys.
    //   Numbers with fewer than 3 digits have waviness = 0.
    //
    // Examples:
    //   120  → digits [1,2,0]: middle digit 2 &gt; 1 and 2 &gt; 0 → peak → waviness 1
    //   4848 → digits [4,8,4,8]:
    //            8 at idx 1: &gt; 4 and &gt; 4 → peak   (+1)
    //            4 at idx 2: &lt; 8 and &lt; 8 → valley (+1)
    //            → waviness 2
    //   198  → digits [1,9,8]: 9 &gt; 1 and 9 &gt; 8 → peak → waviness 1
    //
    // Approach: Brute force with digit extraction
    //   For each number x in [num1, num2]:
    //     1. Extract digits into an array (least-significant first via % 10).
    //     2. If fewer than 3 digits: waviness = 0.
    //     3. Otherwise: scan interior digits (indices 1..len-2),
    //        count peaks and valleys.
    //   Sum all waviness values.
    //
    // Note: constraints for Part I allow a direct loop (num2 &lt;= 10^5),
    //       so this O((num2 - num1) * d) solution passes comfortably.
    //
    // Time : O((num2 - num1) * d)  where d = max digits (~6 for 10^5)
    // Space: O(d)

    // Compute waviness of a single number x
    int waviness(int x) {
        // Extract digits in reverse (least-significant first)
        int digits[10];
        int len = 0;
        while (x &gt; 0) {
            digits[len++] = x % 10;
            x /= 10;
        }

        // Numbers with fewer than 3 digits always have waviness 0
        if (len &lt; 3) return 0;

        // digits[0] is least significant, digits[len-1] is most significant.
        // The "first digit" (leftmost) is digits[len-1] and
        // the "last digit" (rightmost) is digits[0].
        // Interior digits: indices 1 .. len-2.
        int count = 0;
        for (int i = 1; i &lt; len - 1; i++) {
            int prev = digits[i - 1];
            int cur  = digits[i];
            int next = digits[i + 1];

            if (cur &gt; prev &amp;&amp; cur &gt; next) count++;  // peak
            if (cur &lt; prev &amp;&amp; cur &lt; next) count++;  // valley
        }
        return count;
    }

    int totalWaviness(int num1, int num2) {
        int ans = 0;
        for (int x = num1; x &lt;= num2; x++) {
            ans += waviness(x);
        }
        return ans;
    }
};</code></pre>
        </div>
