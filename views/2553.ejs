<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Given an array of positive integers nums, return an array
    // of the individual digits of each number in the same order
    // they appear in nums.
    //
    // Example: nums = [13, 25, 83, 77]
    //          Output = [1, 3, 2, 5, 8, 3, 7, 7]
    //
    // Approach:
    //   For each number, extract its digits using repeated modulo + division.
    //   Division naturally yields digits in reverse order (least significant first),
    //   so we collect them into a temporary buffer, reverse it, then
    //   append to the answer.
    //
    // Time : O(D)  where D = total digits across all numbers
    // Space: O(D)  for the output array

    vector&lt;int&gt; separateDigits(vector&lt;int&gt;&amp; nums) {
        vector&lt;int&gt; ans;

        for (int num : nums) {
            vector&lt;int&gt; digits;

            // Extract digits least-significant first
            while (num &gt; 0) {
                digits.push_back(num % 10);
                num /= 10;
            }

            // Reverse to restore most-significant-first order
            reverse(digits.begin(), digits.end());

            // Append this number's digits to the final answer
            for (int d : digits) {
                ans.push_back(d);
            }
        }

        return ans;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
