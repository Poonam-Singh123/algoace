        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // From index i you can jump to:
    //   i + arr[i]  (forward)
    //   i - arr[i]  (backward)
    // Jumps must stay within [0, n-1].
    // Return true if any index with value 0 is reachable from `start`.
    //
    // Approach: BFS (or DFS) from `start`.
    //   - Use a `visited` array to avoid revisiting indices (prevents cycles).
    //   - For each index dequeued, check if arr[index] == 0 → found!
    //   - Otherwise enqueue both valid neighbours if not yet visited.
    //
    // Why BFS over DFS?
    //   Both are O(n) here. BFS finds the shortest path (fewest jumps)
    //   as a bonus; DFS uses less queue overhead and is equally correct.
    //   We show BFS for clarity, then provide DFS as an alternative.
    //
    // Time : O(n)    Space: O(n)

    // ── BFS solution ────────────────────────────────────────────────
    bool canReach(vector&lt;int&gt;&amp; arr, int start) {
        int n = arr.size();
        vector&lt;bool&gt; visited(n, false);
        queue&lt;int&gt; q;

        q.push(start);
        visited[start] = true;

        while (!q.empty()) {
            int i = q.front();
            q.pop();

            // Found a zero-valued index
            if (arr[i] == 0) return true;

            // Try both jump directions
            int fwd = i + arr[i];
            int bwd = i - arr[i];

            if (fwd &lt; n &amp;&amp; !visited[fwd]) {
                visited[fwd] = true;
                q.push(fwd);
            }
            if (bwd &gt;= 0 &amp;&amp; !visited[bwd]) {
                visited[bwd] = true;
                q.push(bwd);
            }
        }

        return false;   // No zero reachable
    }

    // ── DFS alternative (recursive) ─────────────────────────────────
    // bool canReach(vector&lt;int&gt;&amp; arr, int start) {
    //     return dfs(arr, start, vector&lt;bool&gt;(arr.size(), false));
    // }
    // bool dfs(vector&lt;int&gt;&amp; arr, int i, vector&lt;bool&gt; visited) {
    //     if (i &lt; 0 || i &gt;= (int)arr.size() || visited[i]) return false;
    //     if (arr[i] == 0) return true;
    //     visited[i] = true;
    //     return dfs(arr, i + arr[i], visited) ||
    //            dfs(arr, i - arr[i], visited);
    // }
};</code></pre>
        </div>
