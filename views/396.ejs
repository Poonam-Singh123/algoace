<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int maxRotateFunction(vector&lt;int&gt;&amp; nums) {
        int n = nums.size();

        // Compute total sum of array
        long long sumAll = 0;
        for (int x : nums) sumAll += x;

        // Compute F(0) = 0*nums[0] + 1*nums[1] + ... + (n-1)*nums[n-1]
        long long f = 0;
        for (int i = 0; i &lt; n; i++) {
            f += (long long)i * nums[i];
        }

        // Key recurrence:
        // F(k) = F(k-1) + sumAll - n * nums[n - k]
        //
        // Derivation:
        // When we rotate by 1 clockwise, nums[n-1] moves to index 0,
        // and every other element moves one index to the right (+1 weight).
        // So each element gains weight 1  =>  F(k) = F(k-1) + sumAll
        // But nums[n-k] (which wraps to index 0) loses weight (n-1) instead of gaining 1,
        // i.e., it loses n weight in total  =>  subtract n * nums[n-k].

        long long ans = f;
        for (int k = 1; k &lt; n; k++) {
            f = f + sumAll - (long long)n * nums[n - k];
            ans = max(ans, f);
        }

        return (int)ans;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
