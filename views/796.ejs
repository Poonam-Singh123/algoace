<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    bool rotateString(string s, string goal) {
        // Quick length check — rotations never change length
        if (s.size() != goal.size()) return false;

        // Key insight:
        // Every possible rotation of s appears as a substring of (s + s).
        //
        // Example: s = "abcde"
        //   s + s = "abcdeabcde"
        //   Rotations: "abcde", "bcdea", "cdeab", "deabc", "eabcd"
        //   All of them are substrings of "abcdeabcde".
        //
        // So we just need to check whether goal is a substring of s + s.
        // std::string::find returns string::npos if not found.

        string doubled = s + s;
        return doubled.find(goal) != string::npos;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
