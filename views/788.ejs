<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int rotatedDigits(int n) {
        // dp[i] encodes the rotation state of number i:
        //   0 = invalid (contains 3, 4, or 7 — cannot be rotated)
        //   1 = valid but unchanged after rotation (only 0, 1, 8)
        //   2 = valid AND different after rotation (contains at least one of 2,5,6,9)
        // Only dp[i] == 2 counts as a "good" number.

        vector&lt;int&gt; dp(n + 1, 0);
        int ans = 0;

        for (int i = 0; i &lt;= n; i++) {
            if (i &lt; 10) {
                // Base cases: single digits
                if (i == 0 || i == 1 || i == 8) {
                    dp[i] = 1;          // rotates to itself
                } else if (i == 2 || i == 5 || i == 6 || i == 9) {
                    dp[i] = 2;          // rotates to a different valid digit
                    ans++;
                }
                // digits 3, 4, 7 stay dp[i] = 0 (invalid)
            } else {
                // Multi-digit: combine state of (i / 10) and last digit (i % 10)
                int hi = dp[i / 10];   // state of all digits except the last
                int lo = dp[i % 10];   // state of the last digit

                if (hi &gt;= 1 &amp;&amp; lo &gt;= 1) {
                    // Both parts are at least valid (no 3/4/7 anywhere)
                    if (hi == 2 || lo == 2) {
                        // At least one part changes on rotation =&gt; good number
                        dp[i] = 2;
                        ans++;
                    } else {
                        // Both parts stay the same =&gt; number unchanged after rotation
                        dp[i] = 1;
                    }
                }
                // Otherwise dp[i] remains 0 (invalid)
            }
        }

        return ans;
    }
};</code></pre>
        </div>
