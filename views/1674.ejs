<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Problem: Given array nums (even length) and limit,
    // in one move replace any element with a value in [1, limit].
    // Make nums "complementary": nums[i] + nums[n-1-i] = same value T for all i.
    // Return minimum moves.
    //
    // Key insight: For each pair (a, b) where a = min, b = max of the mirrored pair,
    // the cost to achieve target sum T falls into 5 ranges:
    //
    //   T in [2,       a+1)      : cost 2  (replace both)
    //   T in [a+1,     a+b)      : cost 1  (replace b's element)
    //   T == a+b                 : cost 0  (already perfect)
    //   T in (a+b,     b+limit]  : cost 1  (replace a's element)
    //   T in (b+limit, 2*limit]  : cost 2  (replace both)
    //
    // We use a DIFFERENCE ARRAY over T in [2, 2*limit] to accumulate
    // cost changes across all pairs in O(1) per pair, then find the
    // minimum prefix sum in O(limit) — giving O(n + limit) overall.

    int minMoves(vector&lt;int&gt;&amp; nums, int limit) {
        int n = nums.size();

        // diff has size 2*limit+2 to safely index up to 2*limit+1
        vector&lt;int&gt; diff(2 * limit + 2, 0);

        for (int i = 0; i &lt; n / 2; i++) {
            int a = min(nums[i], nums[n - 1 - i]);
            int b = max(nums[i], nums[n - 1 - i]);

            // Base cost: 2 for the entire range [2, 2*limit]
            diff[2]             += 2;
            diff[2 * limit + 1] -= 2;

            // Range [a+1, 2*limit]: save 1 move (cost drops from 2 to 1)
            diff[a + 1]         -= 1;
            diff[2 * limit + 1] += 1;

            // Range [a+b, a+b]: save another move (cost drops from 1 to 0)
            diff[a + b]         -= 1;
            diff[a + b + 1]     += 1;

            // Range [b+limit+1, 2*limit]: cost goes back up by 1 (from 1 to 2)
            diff[b + limit + 1] += 1;
            diff[2 * limit + 1] -= 1;
        }

        // Find minimum prefix sum over [2, 2*limit]
        int ans = n;   // worst case: n/2 pairs * 2 moves each = n
        int cur = 0;
        for (int t = 2; t &lt;= 2 * limit; t++) {
            cur += diff[t];
            ans = min(ans, cur);
        }

        return ans;
    }
};</code></pre>
        </div>
