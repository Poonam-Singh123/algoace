            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Given two sorted (non-decreasing) integer arrays nums1 and nums2,
    // return the MINIMUM integer common to both. Return -1 if none exists.
    //
    // Approach: Two Pointers
    //   Since both arrays are already sorted, we can walk through them
    //   simultaneously with two pointers i and j:
    //
    //   - nums1[i] == nums2[j]  →  found the smallest common value, return it.
    //   - nums1[i] &lt;  nums2[j]  →  advance i (nums1 is behind, catch up).
    //   - nums1[i] &gt;  nums2[j]  →  advance j (nums2 is behind, catch up).
    //
    //   Because we scan from left to right and both arrays are sorted,
    //   the FIRST match we find is guaranteed to be the minimum common value.
    //
    // Why Two Pointers over a Hash Set?
    //   Hash set: O(n + m) time, O(min(n,m)) space.
    //   Two pointers: O(n + m) time, O(1) space — no extra memory needed.
    //   Both are optimal in time; two pointers wins on space.
    //
    // Time : O(n + m)    Space: O(1)

    int getCommon(vector&lt;int&gt;&amp; nums1, vector&lt;int&gt;&amp; nums2) {
        int i = 0, j = 0;
        int n = nums1.size(), m = nums2.size();

        while (i &lt; n &amp;&amp; j &lt; m) {
            if (nums1[i] == nums2[j]) {
                return nums1[i];        // First (smallest) common value found
            } else if (nums1[i] &lt; nums2[j]) {
                i++;                    // nums1 is behind — advance it
            } else {
                j++;                    // nums2 is behind — advance it
            }
        }

        return -1;  // No common value exists
    }
};</code></pre>
        </div>
