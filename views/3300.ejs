<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Replace every element in nums with its digit sum.
    // Return the minimum element after all replacements.
    //
    // Key observation:
    //   Digit sum of x is always &lt;= x  (e.g. 999 -&gt; 27, 10 -&gt; 1).
    //   Single-digit numbers are their own digit sum.
    //   So we never need to actually modify the array —
    //   compute each digit sum on the fly and track the running minimum.
    //
    // Digit sum helper:
    //   Repeatedly take x % 10 (last digit) and divide x by 10,
    //   accumulating the sum until x == 0.
    //
    // Examples:
    //   digitSum(10)  = 1 + 0 = 1
    //   digitSum(999) = 9 + 9 + 9 = 27
    //   digitSum(199) = 1 + 9 + 9 = 19
    //
    // Time : O(n * d)  where d = number of digits per element (&lt;= 10)
    // Space: O(1)

    // Compute the sum of digits of a positive integer x
    int digitSum(int x) {
        int sum = 0;
        while (x &gt; 0) {
            sum += x % 10;
            x   /= 10;
        }
        return sum;
    }

    int minElement(vector&lt;int&gt;&amp; nums) {
        int ans = INT_MAX;

        for (int x : nums) {
            ans = min(ans, digitSum(x));
        }

        return ans;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
