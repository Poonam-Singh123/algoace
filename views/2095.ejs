            <pre><code class="language-cpp">/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    // Delete the MIDDLE node of a singly linked list and return its head.
    // Middle = node at index floor(n / 2) (0-indexed).
    //
    // Examples:
    //   [1,3,4,7,1,2,6]  n=7, mid=3 (val=7)  →  [1,3,4,1,2,6]
    //   [1,2,3,4]        n=4, mid=2 (val=3)  →  [1,2,4]
    //   [2,1]            n=2, mid=1 (val=1)  →  [2]
    //   [1]              n=1, mid=0 (val=1)  →  []
    //
    // Approach: Modified slow/fast pointer — track the node BEFORE the middle.
    //   Classic slow/fast gives us the middle node itself, but to delete it
    //   we need the node BEFORE it so we can rewire `prev->next`.
    //
    //   Trick: start slow one step BEHIND by using a dummy node:
    //     dummy -> head
    //     slow  = dummy    (starts one behind head)
    //     fast  = head     (starts at head)
    //
    //   When fast reaches the end, slow is exactly at the node
    //   BEFORE the middle. Then:
    //     slow->next = slow->next->next   (skip the middle node)
    //
    //   This works for all lengths including single-element lists
    //   (fast starts at head which is null → loop doesn't run →
    //    slow = dummy → dummy->next = dummy->next->next = nullptr → empty list).
    //
    // Time : O(n)    Space: O(1)

    ListNode* deleteMiddle(ListNode* head) {
        // Edge case: single node → result is empty list
        if (!head || !head-&gt;next) return nullptr;

        // Dummy node whose next points to head;
        // slow starts here so it lags one step behind the standard middle.
        ListNode dummy(0, head);
        ListNode* slow = &amp;dummy;
        ListNode* fast = head;

        // Advance fast by 2 and slow by 1 each iteration.
        // When fast can't move 2 more steps, slow->next is the middle.
        while (fast &amp;&amp; fast-&gt;next) {
            slow = slow-&gt;next;
            fast = fast-&gt;next-&gt;next;
        }

        // Delete the middle node
        ListNode* toDelete = slow-&gt;next;
        slow-&gt;next = slow-&gt;next-&gt;next;
        delete toDelete;   // Free memory

        return dummy.next;
    }
};</code></pre>
