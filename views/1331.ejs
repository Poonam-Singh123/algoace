<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Replace each element of arr with its rank.
    // Rules:
    //   - Rank starts from 1.
    //   - Larger element → larger rank.
    //   - Equal elements → same rank.
    //   - Rank should be as small as possible (no gaps).
    //
    // Approach: Sort + Hash Map  O(n log n)
    //
    //   1. Copy arr into sorted order to determine the rank of each unique value.
    //   2. Walk through sorted values, assigning rank 1, 2, 3, ...
    //      Identical adjacent values get the same rank (rank only increments
    //      when the value actually changes).
    //   3. Store value → rank in an unordered_map.
    //   4. Replace each original element with its mapped rank.
    //
    // Why this works:
    //   Sorting gives us the natural ordering. Walking left to right and
    //   incrementing only on value change ensures no gaps in ranks and
    //   equal values share a rank — exactly the three rules required.
    //
    // Example 1: arr = [40,10,20,30]
    //   Sorted: [10,20,30,40]
    //   rank: {10→1, 20→2, 30→3, 40→4}
    //   Output: [4,1,2,3] ✓
    //
    // Example 2: arr = [100,100,100]
    //   Sorted: [100,100,100]
    //   rank: {100→1}  (rank stays 1, value never changes)
    //   Output: [1,1,1] ✓
    //
    // Example 3: arr = [37,12,28,9,100,56,80,5,12]
    //   Sorted: [5,9,12,12,28,37,56,80,100]
    //   rank: {5→1,9→2,12→3,28→4,37→5,56→6,80→7,100→8}
    //   Output: [5,3,4,2,8,6,7,1,3] ✓
    //
    // Time : O(n log n)    Space: O(n)

    vector&lt;int&gt; arrayRankTransform(vector&lt;int&gt;&amp; arr) {
        int n = arr.size();
        if (n == 0) return {};

        // Step 1: Sort a copy to determine rank order
        vector&lt;int&gt; sorted = arr;
        sort(sorted.begin(), sorted.end());

        // Step 2: Build value → rank map
        // Rank increments only when the value changes
        unordered_map&lt;int, int&gt; rankMap;
        int r = 0;
        for (int i = 0; i &lt; n; i++) {
            if (i == 0 || sorted[i] != sorted[i - 1]) {
                r++;   // New distinct value → next rank
            }
            rankMap[sorted[i]] = r;
        }

        // Step 3: Replace each element with its rank
        vector&lt;int&gt; ans(n);
        for (int i = 0; i &lt; n; i++) {
            ans[i] = rankMap[arr[i]];
        }

        return ans;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
