<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;vector&lt;char&gt;&gt; rotateTheBox(vector&lt;vector&lt;char&gt;&gt;&amp; box) {
        int m = box.size();
        int n = box[0].size();

        // Step 1: Simulate gravity — stones fall to the RIGHT
        // (right side becomes the bottom after 90° clockwise rotation).
        // For each row, use a pointer `fall` tracking the next available
        // position a stone can settle into.
        for (int i = 0; i &lt; m; i++) {
            int fall = n - 1;  // rightmost available landing spot
            for (int j = n - 1; j &gt;= 0; j--) {
                if (box[i][j] == '*') {
                    // Obstacle: cannot move, reset landing pointer
                    // to just left of the obstacle.
                    fall = j - 1;
                } else if (box[i][j] == '#') {
                    // Stone: move it to the `fall` position,
                    // clear its original cell, then decrement `fall`.
                    box[i][fall] = '#';
                    if (fall != j) box[i][j] = '.';
                    fall--;
                }
                // Empty '.': skip, do nothing
            }
        }

        // Step 2: Rotate the box 90 degrees clockwise.
        // Rotation formula: result[i][j] = box[m - 1 - j][i]
        // Original m x n  =>  Result n x m
        //
        // Visual (m=2, n=3):
        //   Original       After gravity    After rotation
        //   # . *  .         # * .              # #
        //   # # *  .         # # * .       =>   . .
        //                                        * *
        //                                        . .

        vector&lt;vector&lt;char&gt;&gt; result(n, vector&lt;char&gt;(m, '.'));
        for (int i = 0; i &lt; n; i++) {
            for (int j = 0; j &lt; m; j++) {
                result[i][j] = box[m - 1 - j][i];
            }
        }

        return result;
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
