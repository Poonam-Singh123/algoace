<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title || 'LeetCode Solution' %>
    </title>
    <link rel="stylesheet" href="/styles.min.css" />
    <link rel="stylesheet" href="/styles.css" />
    <script src="/solution.js"></script>
</head>
<body>
    <main>
        <h1>LeetCode <%= problemNumber %>: <%= problemTitle || 'Problem ' + problemNumber %> (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                <%= problemDescription || 'Problem description will be loaded here.' %>
            </p>
            <p><strong>Example:</strong>
                <%= example || 'Example will be loaded here.' %>
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    void rotate(vector&lt;vector&lt;int&gt;&gt;&amp; matrix) {
        int n = matrix.size();

        // Step 1: Transpose the matrix
        // Swap matrix[i][j] with matrix[j][i] for all i &lt; j.
        // This reflects the matrix along the main diagonal.
        //
        // Before transpose (3x3 example):
        //   1 2 3        1 4 7
        //   4 5 6  -&gt;    2 5 8
        //   7 8 9        3 6 9

        for (int i = 0; i &lt; n; i++) {
            for (int j = i + 1; j &lt; n; j++) {
                swap(matrix[i][j], matrix[j][i]);
            }
        }

        // Step 2: Reverse each row
        // Reversing every row after transposing gives a 90-degree
        // clockwise rotation.
        //
        // After reversing rows:
        //   1 4 7        7 4 1
        //   2 5 8  -&gt;    8 5 2
        //   3 6 9        9 6 3

        for (int i = 0; i &lt; n; i++) {
            reverse(matrix[i].begin(), matrix[i].end());
        }

        // Combined effect:
        // Original -&gt; Transpose -&gt; Reverse rows = 90-degree clockwise rotation
        //
        //   1 2 3        7 4 1
        //   4 5 6  -&gt;    8 5 2
        //   7 8 9        9 6 3
    }
};</code></pre>
        </div>
        <a href="/" class="back-link">&#8592; Back to Home</a>
    </main>
</body>
</html>
